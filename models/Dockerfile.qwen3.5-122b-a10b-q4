# Target hardware: 4x RTX 5090 (128GB VRAM total)
# Model: 76GB — leaves ~52GB for KV cache across all GPUs
# MoE model: only ~10B params active per token despite 122B total weights
FROM ghcr.io/elliottmatt/llama-runpod:latest

ENV MODEL_URL="unsloth/Qwen3.5-122B-A10B-GGUF:Q4_K_M"

# Context: 128k, KV cache q4_0, tensor split evenly across 4 GPUs
ENV LLAMA_ARGS="-c 131072 -ctk q4_0 -ctv q4_0 -ngl 99 --tensor-split 1,1,1,1 -np 1 --temp 1.0 --top-p 0.95 --top-k 20 --min-p 0.0 --reasoning off"
